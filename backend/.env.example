# Application Settings
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=true

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vinschool_ai
POSTGRES_USER=vinschool
POSTGRES_PASSWORD=vinschool_password

# Milvus Configuration
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_PREFIX=vinschool

# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Default LLM Provider (openai, google, anthropic)
DEFAULT_PROVIDER=openai

# Embedding Model Configuration
# For Gemini: text-embedding-004 (dimension: 768)
# For OpenAI: text-embedding-3-small (dimension: 1536)
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=768

# Agent Configuration
DEFAULT_LLM_MODEL=gpt-4-turbo-preview
GRADING_LLM_MODEL=gpt-4-turbo-preview
TEMPERATURE=0.7
MAX_TOKENS=2000

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=.pdf,.docx,.pptx,.jpg,.jpeg,.png

# Workflow Configuration
ENABLE_AUTO_GRADING=true
ENABLE_QUESTION_ROUTING=true
TEACHER_ESCALATION_THRESHOLD=0.6

# Notification Configuration
# Email (SMTP) - for sending teacher notifications via email
ENABLE_EMAIL_NOTIFICATIONS=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
NOTIFICATION_SENDER_EMAIL=ai-assistant@vinschool.edu.vn
NOTIFICATION_SENDER_NAME=Vinschool AI Assistant

# Google Chat - for sending notifications to Google Chat spaces
ENABLE_GOOGLE_CHAT_NOTIFICATIONS=false
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/xxx/messages?key=yyy
NOTIFICATION_TIMEOUT=30

# Security
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
