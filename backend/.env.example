# Application Settings
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=true

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vinschool_ai
POSTGRES_USER=vinschool
POSTGRES_PASSWORD=vinschool_password

# Milvus Configuration
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_PREFIX=vinschool

# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=AIzaSyDFItxCuKdHdckSOQZMjpRlkjzGNoI9ET0

# Default LLM Provider (openai, google, anthropic)
DEFAULT_PROVIDER=google

# Embedding Model Configuration
# For Gemini: text-embedding-004 (dimension: 768)
# For OpenAI: text-embedding-3-small (dimension: 1536)
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=768

# Agent Configuration
DEFAULT_LLM_MODEL=gemini-1.5-pro
GRADING_LLM_MODEL=gemini-1.5-pro
TEMPERATURE=0.7
MAX_TOKENS=2000

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=.pdf,.docx,.pptx,.jpg,.jpeg,.png

# Workflow Configuration
ENABLE_AUTO_GRADING=true
ENABLE_QUESTION_ROUTING=true
TEACHER_ESCALATION_THRESHOLD=0.6

# Security
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
