# Application Settings
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=true

# Database Configuration
# Option A: Full DATABASE_URL (Render, Heroku, Neon, etc.)
#   When set, individual POSTGRES_* vars below are ignored for connections.
#   For Render: use the EXTERNAL hostname (dpg-xxx-a.region.render.com).
#     The internal hostname (dpg-xxx-a) is only reachable from inside Render.
DATABASE_URL=
# Option B: Individual vars (local Docker Compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vinschool_ai
POSTGRES_USER=vinschool
POSTGRES_PASSWORD=vinschool_password

# Milvus Configuration
# Collections are auto-created: documents (vinschool_documents) and grading results (vinschool_grading_results)
# Option A: Zilliz Cloud (managed Milvus)
#   Set MILVUS_URI + MILVUS_TOKEN; leave MILVUS_HOST empty.
MILVUS_URI=
MILVUS_TOKEN=
# Option B: Local Milvus (Docker Compose)
#   Leave MILVUS_URI empty; set MILVUS_HOST + MILVUS_PORT.
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_PREFIX=vinschool

# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Default LLM Provider (openai, google, anthropic)
DEFAULT_PROVIDER=google

# Embedding Model Configuration
# For Gemini: gemini-embedding-001 (dimension: 768)
# For OpenAI: text-embedding-3-small (dimension: 1536)
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=768

# Agent Configuration
DEFAULT_LLM_MODEL=gemini-1.5-pro
GRADING_LLM_MODEL=gemini-1.5-pro
TEMPERATURE=0.7
MAX_TOKENS=2000

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=.pdf,.docx,.pptx,.jpg,.jpeg,.png

# Workflow Configuration
ENABLE_AUTO_GRADING=true
ENABLE_QUESTION_ROUTING=true
TEACHER_ESCALATION_THRESHOLD=0.6

# Notification & Chat Configuration
## Email (SMTP)
ENABLE_EMAIL_NOTIFICATIONS=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true

### Teacher Escalation
TEACHER_EMAIL=teacher@vinschool.edu.vn,teacher2@vinschool.edu.vn
NOTIFICATION_SENDER_EMAIL=your-email@gmail.com
NOTIFICATION_SENDER_NAME=Vinschool AI Assistant

### Low Grade Alert
LOW_GRADE_THRESHOLD=7.0

## Google Chat
### Google Chat Webhook
ENABLE_GOOGLE_CHAT_NOTIFICATIONS=false
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/xxx/messages?key=yyy
NOTIFICATION_TIMEOUT=30

### Google Chat Bot (Pub/Sub)
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_CHAT_PUBSUB_SUBSCRIPTION=projects/your-gcp-project-id/subscriptions/chat-events-sub
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...@...iam.gserviceaccount.com",...}
GOOGLE_CHAT_SPACE_ID=spaces/AAAAxxxxxx

## Chat debounce (seconds of quiet before batched messages are sent to AI)
CHAT_DEBOUNCE_SECONDS=3.0

## Zalo
ENABLE_ZALO_NOTIFICATIONS=false
ZALO_OA_ACCESS_TOKEN=your-zalo-oa-access-token

## Daily Summary Scheduler (24-hour clock)
DAILY_SUMMARY_HOUR=18
DAILY_SUMMARY_MINUTE=0

# Security
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
